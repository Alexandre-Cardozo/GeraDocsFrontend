{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "@/components/ds/actions",
              "@/components/ds/feedback",
              "@/components/ds/forms",
              "@/components/ds/navigation"
            ],
            "message": "Import design-system components from '@/components/ds', not component internals."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "components/ds/**"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
