{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/chrome/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/geradocs/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Plus Jakarta Sans|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Plus Jakarta Sans, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|disabled|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, disabled, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|dark|success|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'dark' | 'success' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onClick|icon|title|desc|size|key|ref|className|style|children)$/]",
        "message": "<ChoiceCard> doesn't accept that prop. Declared props: selected, onClick, icon, title, desc, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChoiceCard'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:normal|small)$/]",
        "message": "<ChoiceCard> size must be one of 'normal' | 'small'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DocPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|bg|color|key|ref|className|style|children)$/]",
        "message": "<DocPill> doesn't accept that prop. Declared props: status, bg, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='FileUpload'] > JSXAttribute > JSXIdentifier[name!=/^(?:file|onChange|placeholder|accept|key|ref|className|style|children)$/]",
        "message": "<FileUpload> doesn't accept that prop. Declared props: file, onChange, placeholder, accept."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|hint|children|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, required, hint, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|cta|onCta|children|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: title, cta, onCta, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:prefix|placeholder|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: prefix, placeholder, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|kbd|width|background|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: placeholder, value, onChange, kbd, width, background."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|hint|children|key|ref|className|style|children)$/]",
        "message": "<SectionBlock> doesn't accept that prop. Declared props: title, hint, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:currentView|navigate|items|bottomItems|orgName|orgUnit|userName|userRole|userInitials|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: currentView, navigate, items, bottomItems, orgName, orgUnit, userName, userRole, userInitials."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|trend|icon|color|bg|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, sub, trend, icon, color, bg."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='trend'] > Literal[value!=/^(?:up|warn)$/]",
        "message": "<StatCard> trend must be one of 'up' | 'warn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:rascunho|em_revisao|aguardando|aprovado|rejeitado|concluido)$/]",
        "message": "<StatusBadge> status must be one of 'rascunho' | 'em_revisao' | 'aguardando' | 'aprovado' | 'rejeitado' | 'concluido'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatusBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|current|key|ref|className|style|children)$/]",
        "message": "<StepIndicator> doesn't accept that prop. Declared props: steps, current."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|color|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='ValidationMsg'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|msg|key|ref|className|style|children)$/]",
        "message": "<ValidationMsg> doesn't accept that prop. Declared props: type, msg."
      },
      {
        "selector": "JSXOpeningElement[name.name='ValidationMsg'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:ok|warn|error)$/]",
        "message": "<ValidationMsg> type must be one of 'ok' | 'warn' | 'error'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
